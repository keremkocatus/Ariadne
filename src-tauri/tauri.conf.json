{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ariadne",
  "version": "0.1.1",
  "identifier": "com.ariadne.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ariadne — PostgreSQL IDE",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGMDA4QzAwRDQwM0EwQjEKUldTeG9BUFVBSXdBYnc4NmZEd1ZmWjFpVkYxcVVwaGF4MVFINFhqRi9PSVlUckVJR28wejNudzMK",
      "endpoints": [
        "https://github.com/keremkocatus/Ariadne/releases/latest/download/latest.json"
      ]
    }
  }
}
